generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         Int                     @id @default(autoincrement())
  publicId                   String                  @unique @default(cuid())
  vendorProfileId            Int?                    @unique
  email                      String                  @unique
  phone                      String?                 @unique
  password                   String?
  role                       Role                    @default(CUSTOMER)
  roleUpdatedById            Int?
  isEmailVerified            Boolean                 @default(false)
  isPhoneVerified            Boolean                 @default(false)
  isActive                   Boolean                 @default(true)
  isBanned                   Boolean                 @default(false)
  lastLoginAt                DateTime?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  accountInfo                AccountInfo?
  addresses                  Address[]
  roleUpdatedBy              User?                   @relation("RoleUpdater", fields: [roleUpdatedById], references: [id])
  cart                       Cart?
  couponsUsed                CouponUsage[]
  notifications              Notification[]
  oauthAccounts              OAuthAccount[]
  orders                     Order[]
  pushSubscriptions          PushSubscription[]
  returnRequests             ReturnRequest[]
  reviewVotes                ReviewVote[]
  reviews                    Review[]
  searchHistory              SearchHistory[]
  sessions                   Session[]
  vendorProfile              VendorProfile?          @relation("vendorProfile")
  wallet                     Wallet?
  wishlist                   Wishlist?
  flashSalesCreated          FlashSale[]             @relation("FlashSaleCreator")
  orderStatusUpdates         Order[]                 @relation("OrderStatusUpdater")
  productStatusUpdates       Product[]               @relation("ProductStatusUpdater")
  flashSaleStatusUpdates     FlashSale[]             @relation("FlashSaleStatusUpdater")
  orderStatusHistories       OrderStatusHistory[]    @relation("OrderStatusHistoryUpdater")
  returnRequestStatusUpdates ReturnRequest[]         @relation("ReturnRequestStatusUpdater")
  reviewStatusUpdates        Review[]                @relation("ReviewStatusUpdater")
  couponsCreated             Coupon[]                @relation("couponsCreated")
  flashSaleItems             FlashSaleItem[]         @relation("FlashSaleItemAdder")
  productAttributes          ProductAttribute[]      @relation("ProductAttributeAdder")
  productDiscounts           ProductDiscount[]       @relation("ProductDiscountCreator")
  shipmentsCreated           Shipment[]              @relation("ShipmentCreator")
  roleUpdates                User[]                  @relation("RoleUpdater")
  vendorVerifications        VendorProfile[]         @relation("VendorVerifier")
  vendorWithdrawRequests     VendorWithdrawRequest[] @relation("VendorWithdrawUser")
  vendorWithdrawsPaid        VendorWithdrawRequest[] @relation("WithdrawPaidBy")

  @@index([publicId])
  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model AccountInfo {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  firstName   String
  lastName    String
  displayName String?
  avatar      String?
  dateOfBirth DateTime?
  gender      Gender?
  bio         String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account_infos")
}

model Session {
  id         String   @id @default(cuid())
  userId     Int
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model OAuthAccount {
  id           Int       @id @default(autoincrement())
  userId       Int
  provider     String
  providerUid  String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@index([userId])
  @@map("oauth_accounts")
}

model Address {
  id             Int         @id @default(autoincrement())
  userId         Int
  type           AddressType @default(HOME)
  label          String?
  fullName       String
  phone          String
  addressLine1   String
  addressLine2   String?
  city_district  String
  postalCode     String?
  country        String      @default("BD")
  isDefault      Boolean     @default(false)
  landmark       String?
  latitude       Decimal?    @db.Decimal(10, 7)
  longitude      Decimal?    @db.Decimal(10, 7)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ordersBilling  Order[]     @relation("BillingAddress")
  ordersShipping Order[]     @relation("ShippingAddress")

  @@index([userId])
  @@index([country, city_district])
  @@map("addresses")
}

model VendorProfile {
  id                  Int                     @id @default(autoincrement())
  publicId            String                  @unique @default(cuid())
  userId              Int                     @unique
  storeName           String                  @unique
  slug                String                  @unique
  logo                String?
  banner              String?
  description         String?
  rating              Decimal                 @default(0) @db.Decimal(3, 2)
  totalSales          Int                     @default(0)
  isVerified          Boolean                 @default(false)
  verifiedById        Int?
  isActive            Boolean                 @default(true)
  returnPolicy        String?
  supportEmail        String?
  supportPhone        String?
  vendorDue           Decimal                 @default(0) @db.Decimal(12, 2)
  lastPaymentReceived DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  withdrawRequests    VendorWithdrawRequest[]
  products            Product[]
  user                User                    @relation("vendorProfile", fields: [userId], references: [id])
  verifiedBy          User?                   @relation("VendorVerifier", fields: [verifiedById], references: [id], onDelete: Restrict)
  flashSales          FlashSale[]

  @@index([publicId])
  @@index([slug])
  @@index([isVerified, isActive])
  @@map("vendor_profiles")
}

model VendorWithdrawRequest {
  id                Int                   @id @default(autoincrement())
  publicId          String                @unique @default(cuid())
  vendorId          Int
  userId            Int
  description       String?
  paymentMethod     String
  amount            Decimal               @db.Decimal(12, 2)
  status            WithdrawRequestStatus @default(PENDING)
  paidThrough       String?
  paidById          Int?
  paidOn            DateTime?
  cancelReason      String?
  processingDetails String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  vendor            VendorProfile         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user              User                  @relation("VendorWithdrawUser", fields: [userId], references: [id])
  paidBy            User?                 @relation("WithdrawPaidBy", fields: [paidById], references: [id])

  @@index([vendorId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("vendor_withdraw_requests")
}

model Category {
  id          Int               @id @default(autoincrement())
  name        String
  slug        String            @unique
  description String?
  image       String?
  icon        String?
  parentId    Int?
  depth       Int               @default(0)
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  parent      Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]        @relation("CategoryTree")
  products    ProductCategory[]

  @@index([parentId])
  @@index([slug])
  @@index([depth, isActive])
  @@map("categories")
}

model Brand {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  logo        String?
  banner      String?
  description String?
  website     String?
  country     String?
  isActive    Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([slug])
  @@index([isActive, isFeatured])
  @@map("brands")
}

model Product {
  id                Int                @id @default(autoincrement())
  publicId          String             @unique @default(cuid())
  vendorId          Int?
  brandId           Int?
  name              String
  slug              String             @unique
  shortDescription  String?
  description       String?
  status            ProductStatus      @default(DRAFT)
  statusUpdatedById Int?
  isFeatured        Boolean            @default(false)
  tags              String[]
  metaTitle         String?
  metaDesc          String?
  metaKeywords      String?
  totalSold         Int                @default(0)
  averageRating     Decimal            @default(0) @db.Decimal(3, 2)
  reviewCount       Int                @default(0)
  viewCount         Int                @default(0)
  wishlistCount     Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  statusUpdatedBy   User?              @relation("ProductStatusUpdater", fields: [statusUpdatedById], references: [id])
  cartItems         CartItem[]
  orderItems        OrderItem[]
  attributes        ProductAttribute[]
  categories        ProductCategory[]
  discounts         ProductDiscount[]
  images            ProductImage[]
  variants          ProductVariant[]
  brand             Brand?             @relation(fields: [brandId], references: [id])
  vendor            VendorProfile?     @relation(fields: [vendorId], references: [id])
  relatedProducts   RelatedProduct[]   @relation("ProductRelations")
  relatedTo         RelatedProduct[]   @relation("RelatedTo")
  reviews           Review[]
  wishlistItems     WishlistItem[]
  flashSaleItem     FlashSaleItem?

  @@index([publicId])
  @@index([slug])
  @@index([status, isFeatured])
  @@index([brandId])
  @@index([vendorId])
  @@index([averageRating])
  @@index([totalSold])
  @@index([createdAt])
  @@map("products")
}

model ProductCategory {
  productId  Int
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_categories")
}

model ProductVariant {
  id            Int                  @id @default(autoincrement())
  publicId      String               @unique @default(cuid())
  productId     Int
  sku           String               @unique
  name          String?
  price         Decimal              @db.Decimal(12, 2)
  comparePrice  Decimal?             @db.Decimal(12, 2)
  costPrice     Decimal?             @db.Decimal(12, 2)
  stock         Int                  @default(0)
  lowStockAlert Int                  @default(5)
  weight        Decimal?             @db.Decimal(8, 3)
  barcode       String?
  isDefault     Boolean              @default(false)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  cartItems     CartItem[]
  inventoryLogs InventoryLog[]
  orderItems    OrderItem[]
  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues  VariantOptionValue[]

  @@index([publicId])
  @@index([productId])
  @@index([sku])
  @@index([stock])
  @@map("product_variants")
}

model ProductOption {
  id     Int                  @id @default(autoincrement())
  name   String
  values ProductOptionValue[]

  @@index([name])
  @@map("product_options")
}

model ProductOptionValue {
  id       Int                  @id @default(autoincrement())
  optionId Int
  value    String
  option   ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants VariantOptionValue[]

  @@unique([optionId, value])
  @@index([optionId])
  @@map("product_option_values")
}

model VariantOptionValue {
  variantId Int
  valueId   Int
  value     ProductOptionValue @relation(fields: [valueId], references: [id], onDelete: Cascade)
  variant   ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([variantId, valueId])
  @@map("variant_option_values")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isPrimary])
  @@map("product_images")
}

model ProductAttribute {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String
  value     String
  addedById Int?
  createdAt DateTime @default(now())
  addedBy   User?    @relation("ProductAttributeAdder", fields: [addedById], references: [id], onDelete: Restrict)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_attributes")
}

model RelatedProduct {
  productId Int
  relatedId Int
  product   Product @relation("ProductRelations", fields: [productId], references: [id], onDelete: Cascade)
  related   Product @relation("RelatedTo", fields: [relatedId], references: [id], onDelete: Cascade)

  @@id([productId, relatedId])
  @@map("related_products")
}

model InventoryLog {
  id          Int            @id @default(autoincrement())
  variantId   Int
  change      Int
  reason      String?
  referenceId Int?
  createdAt   DateTime       @default(now())
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
  @@map("inventory_logs")
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        Int            @id @default(autoincrement())
  cartId    Int
  productId Int
  variantId Int
  quantity  Int            @default(1)
  addedAt   DateTime       @default(now())
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

model Wishlist {
  id        Int            @id @default(autoincrement())
  userId    Int            @unique
  createdAt DateTime       @default(now())
  items     WishlistItem[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wishlists")
}

model WishlistItem {
  id         Int      @id @default(autoincrement())
  wishlistId Int
  productId  Int
  addedAt    DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@map("wishlist_items")
}

model FlashSale {
  id                Int             @id @default(autoincrement())
  publicId          String          @unique @default(cuid())
  title             String
  slug              String          @unique
  description       String?
  banner            String?
  status            FlashSaleStatus @default(DRAFT)
  statusUpdatedById Int?
  startsAt          DateTime
  endsAt            DateTime
  vendorId          Int?
  createdById       Int?
  isActive          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  statusUpdatedBy   User?           @relation("FlashSaleStatusUpdater", fields: [statusUpdatedById], references: [id])
  vendor            VendorProfile?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdBy         User?           @relation("FlashSaleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items             FlashSaleItem[]

  @@index([publicId])
  @@index([slug])
  @@index([status, startsAt, endsAt])
  @@index([vendorId])
  @@index([isActive])
  @@map("flash_sales")
}

model FlashSaleItem {
  id            Int          @id @default(autoincrement())
  publicId      String       @unique @default(cuid())
  flashSaleId   Int
  productId     Int          @unique // ← ONE active offer per product enforced here
  discountType  DiscountType // PERCENTAGE | FLAT — reuse existing enum
  discountValue Decimal      @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2) // cap for percentage type
  originalPrice Decimal      @db.Decimal(12, 2) // snapshot of price at time of offer
  salePrice     Decimal      @db.Decimal(12, 2) // computed and stored
  stock         Int? // optional limit — null = unlimited
  soldCount     Int          @default(0)
  isActive      Boolean      @default(true)
  addedById     Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  addedBy       User?        @relation("FlashSaleItemAdder", fields: [addedById], references: [id], onDelete: Restrict)
  flashSale     FlashSale    @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([flashSaleId])
  @@index([productId])
  @@index([isActive])
  @@map("flash_sale_items")
}

model Order {
  id                Int                  @id @default(autoincrement())
  publicId          String               @unique @default(cuid())
  orderNumber       String               @unique @default(cuid())
  userId            Int
  shippingAddressId Int
  billingAddressId  Int?
  status            OrderStatus          @default(PENDING)
  statusUpdatedById Int?
  subtotal          Decimal              @db.Decimal(12, 2)
  shippingFee       Decimal              @default(0) @db.Decimal(12, 2)
  discount          Decimal              @default(0) @db.Decimal(12, 2)
  tax               Decimal              @default(0) @db.Decimal(12, 2)
  total             Decimal              @db.Decimal(12, 2)
  couponId          Int?
  notes             String?
  cancelReason      String?
  deliveredAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  statusUpdatedBy   User?                @relation("OrderStatusUpdater", fields: [statusUpdatedById], references: [id])
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  billingAddress    Address?             @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: Restrict)
  coupon            Coupon?              @relation(fields: [couponId], references: [id])
  shippingAddress   Address              @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  user              User                 @relation(fields: [userId], references: [id])
  payment           Payment?
  returnRequests    ReturnRequest[]
  shipment          Shipment?

  @@index([publicId])
  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         Int            @id @default(autoincrement())
  orderId    Int
  productId  Int
  variantId  Int
  quantity   Int
  unitPrice  Decimal        @db.Decimal(12, 2)
  totalPrice Decimal        @db.Decimal(12, 2)
  snapshot   Json
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [productId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  review     Review?

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id                Int         @id @default(autoincrement())
  orderId           Int
  status            OrderStatus
  statusUpdatedById Int?
  note              String?
  createdAt         DateTime    @default(now())
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  statusUpdatedBy   User?       @relation("OrderStatusHistoryUpdater", fields: [statusUpdatedById], references: [id])

  @@index([orderId])
  @@map("order_status_histories")
}

model Payment {
  id              Int           @id @default(autoincrement())
  publicId        String        @unique @default(cuid())
  orderId         Int           @unique
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("BDT")
  transactionId   String?       @unique
  gatewayRef      String?
  gatewayResponse Json?
  paidAt          DateTime?
  refundedAmount  Decimal       @default(0) @db.Decimal(12, 2)
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([publicId])
  @@index([status])
  @@index([transactionId])
  @@index([createdAt])
  @@map("payments")
}

model Shipment {
  id             Int       @id @default(autoincrement())
  orderId        Int       @unique
  carrier        String?
  trackingNumber String?
  trackingUrl    String?
  createdById    Int?
  shippedAt      DateTime?
  estimatedAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      User?     @relation("ShipmentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([trackingNumber])
  @@map("shipments")
}

model ReturnRequest {
  id                     Int                        @id @default(autoincrement())
  publicId               String                     @unique @default(cuid())
  orderId                Int
  userId                 Int
  reason                 ReturnReason
  description            String?
  refundAmount           Decimal?                   @db.Decimal(12, 2)
  images                 String[]
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  returnItems            Json                       @default("[]")
  status                 ReturnRequestStatus        @default(PENDING)
  statusUpdatedById      Int?
  statusUpdatedBy        User?                      @relation("ReturnRequestStatusUpdater", fields: [statusUpdatedById], references: [id])
  paidThrough            ReturnRequestRefundMethod? @default(YET_TO_BE_PAID)
  requestedMeansOfRefund String?                    @default("WALLET")
  order                  Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user                   User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([publicId])
  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("return_requests")
}

model Review {
  id                Int          @id @default(autoincrement())
  publicId          String       @unique @default(cuid())
  productId         Int
  userId            Int
  orderItemId       Int?         @unique
  rating            Int
  title             String?
  body              String?
  images            String[]
  status            ReviewStatus @default(APPROVED)
  statusUpdatedById Int?
  isVerified        Boolean      @default(false)
  helpfulCount      Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  votes             ReviewVote[]
  orderItem         OrderItem?   @relation(fields: [orderItemId], references: [id])
  product           Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  statusUpdatedBy   User?        @relation("ReviewStatusUpdater", fields: [statusUpdatedById], references: [id])

  @@unique([productId, userId, orderItemId])
  @@index([publicId])
  @@index([productId, status])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model ReviewVote {
  userId    Int
  reviewId  Int
  isHelpful Boolean
  review    Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
  @@map("review_votes")
}

model Coupon {
  id             Int           @id @default(autoincrement())
  code           String        @unique
  description    String?
  discountType   DiscountType
  discountValue  Decimal       @db.Decimal(10, 2)
  minOrderAmount Decimal?      @db.Decimal(12, 2)
  maxDiscount    Decimal?      @db.Decimal(12, 2)
  usageLimit     Int?
  usedCount      Int           @default(0)
  perUserLimit   Int           @default(1)
  isActive       Boolean       @default(true)
  startsAt       DateTime
  expiresAt      DateTime
  createdById    Int?
  createdAt      DateTime      @default(now())
  createdBy      User?         @relation("couponsCreated", fields: [createdById], references: [id], onDelete: Restrict)
  usages         CouponUsage[]
  orders         Order[]

  @@index([code])
  @@index([isActive, startsAt, expiresAt])
  @@map("coupons")
}

model CouponUsage {
  id       Int      @id @default(autoincrement())
  couponId Int
  userId   Int
  orderId  Int?
  usedAt   DateTime @default(now())
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId, userId])
  @@map("coupon_usages")
}

model ProductDiscount {
  id            Int          @id @default(autoincrement())
  productId     Int
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  startsAt      DateTime
  expiresAt     DateTime
  isActive      Boolean      @default(true)
  createdById   Int?
  createdAt     DateTime     @default(now())
  createdBy     User?        @relation("ProductDiscountCreator", fields: [createdById], references: [id], onDelete: Restrict)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isActive])
  @@index([startsAt, expiresAt])
  @@map("product_discounts")
}

model Wallet {
  id           Int                 @id @default(autoincrement())
  userId       Int                 @unique
  balance      Decimal             @default(0) @db.Decimal(12, 2)
  currency     String              @default("BDT")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions WalletTransaction[]
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallets")
}

model WalletTransaction {
  id       Int                            @id @default(autoincrement())
  publicId String?                        @unique @default(cuid())
  walletId Int
  amount   Decimal                        @db.Decimal(12, 2)
  type     String
  status   WalletTransactionPaymentStatus @default(PENDING)

  transactionId   String?   @unique
  gatewayRef      String    @default("")
  gatewayResponse Json?     @default("{}")
  reason          String    @default("")
  reference       String?   @default("")
  processedAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())
  wallet          Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  query     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("search_histories")
}

